{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack -p 3000 -H 0.0.0.0",
    "dev:turbo": "next dev --turbopack -p 3000 -H 0.0.0.0",
    "build": "next build && pnpm run sw:compile",
    "sw:compile": "serwist build serwist.config.js",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "openapi:gen": "openapi-typescript lib/api/openapi.json -o lib/api/types.generated.ts",
    "check-bundle-size": "node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "5.4.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "1.1.16",
    "@radix-ui/react-dropdown-menu": "2.1.17",
    "@radix-ui/react-label": "2.1.9",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "1.1.9",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "1.2.5",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@scalar/api-reference-react": "^0.9.42",
    "@serwist/next": "9.5.11",
    "@serwist/window": "9.5.11",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "^3.14.2",
    "@use-gesture/react": "^10.3.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "^1.1.1",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.14.0",
    "lucide-react": "1.17.0",
    "next": "16.2.9",
    "next-intl": "4.13.0",
    "next-themes": "0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.78.0",
    "recharts": "^3.8.1",
    "serwist": "9.5.11",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@next/eslint-plugin-next": "16.2.9",
    "@playwright/test": "1.60.0",
    "@serwist/cli": "9.5.11",
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.13.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "esbuild": "^0.28.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "openapi-typescript": "7.13.0",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "^8.0.16",
    "vitest": "4.1.8"
  }
}
