# Rust
target/
**/*.rs.bk
*.pdb

# Node
node_modules/
.pnpm-store/
.next/
out/
.turbo/
*.tsbuildinfo

# Env / secrets
.env
.env.local
.env.*.local
!.env.example

# Local dev data (postgres, redis, fixtures cache).
# Use `.dev-data/*` (not `.dev-data/`) so child re-includes below actually work
# — git's gitignore can't re-include files when their parent dir is excluded.
.dev-data/*
# Nested dev-data dirs under crates/* and web/ hold local secrets/thumbs caches.
**/.dev-data/
data/
# …but keep the committed dev OIDC mock config (Dex container reads this).
!.dev-data/dex-config.yaml

# Non-distributable test fixtures (real comic archives — kept local only).
fixtures/library/
# Stress-test fixture set generated by `python3 fixtures/build.py --scale stress`.
# ~1000 CBZs across ~50 series; used by the perf-profiling pass
# (docs/dev/scanner-perf.md). Re-generate with `just regen-fixtures-stress`.
fixtures/library-stress/

# Per-run artifacts from `just perf-scan` (flamegraph SVG, pg_stat_statements
# dump, phase timings JSON). Not checked in; the doc cites baseline numbers.
perf-out/
perf.data
perf.data.old

# Scratch research notes (kept local).
series_description_examples.md

# OS / editors
.DS_Store
Thumbs.db
*.swp
*~

# Build artifacts
dist/
build/

# Logs
# `*.log` covers per-file output. The bare `logs/` pattern that used to
# be here matched *any* directory named `logs/` anywhere in the tree,
# which silently hid `web/app/[locale]/(admin)/admin/logs/page.tsx`
# and any other route accidentally named "logs". Folio writes
# structured logs to stdout (see crates/server/src/observability.rs),
# so we don't need a generic `logs/` exclusion — `*.log` is enough.
*.log

# Test artifacts
coverage/
playwright-report/
test-results/

# Generated
web/lib/api/types.ts.tmp
web/lib/api/types.generated.ts
crates/server/openapi.json.tmp

# Claude Code — keep shared config (CLAUDE.md, .mcp.json, .claude/commands/,
# .claude/settings.json) but exclude per-machine state and scratch files.
.claude/settings.local.json
.claude/*.lock
.claude/memory_*.md
.claude/tmp/

# Playwright MCP scratch dumps (browser snapshots written by the MCP server).
.playwright-mcp/

# Other AI tools' per-machine config (Codex CLI, etc.).
.codex/
.mcp.json
!.mcp.json.example
