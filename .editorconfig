root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.rs]
indent_size = 4

[*.{toml,md}]
indent_size = 2
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{cbz,cbr,cbt,cb7,zip,rar,7z,tar,png,jpg,jpeg,webp,gif,pdf}]
charset = unset
end_of_line = unset
insert_final_newline = false
trim_trailing_whitespace = false
indent_style = unset
indent_size = unset
