# Comic Reader — environment variables
# Copy to .env and edit. See §12.3 of the spec.
# All variables use the COMIC_ prefix.

# ───── Core ─────
COMIC_DATABASE_URL=postgres://comic:comic@localhost:5432/comic_reader
# Required since Library Scanner v1 — apalis-backed background scan and
# post-scan jobs need Redis. Dev compose publishes redis on host port 6380 to
# avoid colliding with a system valkey/redis daemon on 6379. In prod
# (compose.prod.yml) this is just `redis:6379` inside the docker network — see
# compose.prod.yml for the override.
COMIC_REDIS_URL=redis://localhost:6380
COMIC_LIBRARY_PATH=./fixtures/library
COMIC_DATA_PATH=./.dev-data/app
COMIC_PUBLIC_URL=http://localhost:3000
COMIC_BIND_ADDR=0.0.0.0:8080
COMIC_LOG_LEVEL=info
COMIC_TRUSTED_PROXIES=127.0.0.0/8,::1/128

# ───── Auth mode ─────
# oidc | local | both
COMIC_AUTH_MODE=both

# ───── OIDC (when mode includes oidc) ─────
COMIC_OIDC_ISSUER=http://localhost:5556/dex
COMIC_OIDC_CLIENT_ID=comic-reader
COMIC_OIDC_CLIENT_SECRET=dev-secret-not-for-production
COMIC_OIDC_TRUST_UNVERIFIED_EMAIL=false
# COMIC_OIDC_CLIENT_SECRET_FILE=/run/secrets/oidc

# ───── Local users (when mode includes local) ─────
COMIC_LOCAL_REGISTRATION_OPEN=true
COMIC_LOCAL_REQUIRE_TOTP=false

# ───── Tokens ─────
COMIC_JWT_ACCESS_TTL=24h
COMIC_JWT_REFRESH_TTL=30d

# ───── Rate limiting ─────
COMIC_RATE_LIMIT_ENABLED=true

# ───── Observability ─────
# Empty value → stdout exporter only
COMIC_OTLP_ENDPOINT=

# ───── SMTP (optional; enables local self-serve recovery) ─────
# Leave COMIC_SMTP_HOST empty to disable email features.
COMIC_SMTP_HOST=
COMIC_SMTP_PORT=587
COMIC_SMTP_USERNAME=
COMIC_SMTP_PASSWORD=
COMIC_SMTP_TLS=starttls
# COMIC_SMTP_FROM=noreply@example.com  (uncomment + set when SMTP is configured;
# avoid display-name + angle-brackets here — `just` dotenv parser is strict)
# COMIC_SMTP_DKIM_KEY_FILE=/run/secrets/dkim
# COMIC_SMTP_MAX_PER_HOUR=100

# ───── Scan / archive limits (defaults from §4.1.1) ─────
# COMIC_ARCHIVE_MAX_ENTRIES=50000
# COMIC_ARCHIVE_MAX_TOTAL_BYTES=8589934592
# COMIC_ARCHIVE_MAX_ENTRY_BYTES=536870912
# COMIC_ARCHIVE_MAX_RATIO=200
# COMIC_ARCHIVE_MAX_NESTING=1

# ───── ZIP LRU ─────
# COMIC_ZIP_LRU_CAPACITY=64

# ───── Scanner v1 ─────
# COMIC_SCAN_WORKER_COUNT=4         # parallel scan jobs (default min(cpu, 4); set to 1 in dev to keep API responsive when a backlog drains)
# COMIC_POST_SCAN_WORKER_COUNT=2    # parallel post-scan jobs (thumbs/search)
# COMIC_SCAN_BATCH_SIZE=100         # issues per DB transaction
# COMIC_SCAN_HASH_BUFFER_KB=64      # BLAKE3 streaming buffer

# ───── Migrations ─────
COMIC_AUTO_MIGRATE=true

# ───── Deployment (compose.prod.yml) ─────
# These drive `compose.prod.yml` placeholders; they have no effect on a
# local `cargo run` or `pnpm dev` session.

# GHCR owner/org that holds your published images:
#   ghcr.io/${REPO_OWNER}/folio        (Rust server)
#   ghcr.io/${REPO_OWNER}/folio-web    (Next.js frontend)
REPO_OWNER=your-github-username-or-org

# Image tag to deploy. Use `vX.Y` for hands-off patch upgrades, `vX.Y.Z`
# to pin exactly, `edge` to track main. Default is `latest`.
TAG=latest

# Postgres password for the `comic` user (compose initializes the DB on
# first boot with this value). Pick something long and random.
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# Absolute host path that holds your CBZ/CBR/PDF/EPUB library. Mounted
# read-only into the container.
COMIC_LIBRARY_HOST_PATH=/srv/comics
