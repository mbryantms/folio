# Comic Reader — environment variables
# Copy to .env and edit. See §12.3 of the spec.
# All variables use the COMIC_ prefix.

# ───── Core ─────
COMIC_DATABASE_URL=postgres://comic:comic@localhost:5432/comic_reader
# Required since Library Scanner v1 — apalis-backed background scan and
# post-scan jobs need Redis. Dev compose publishes redis on host port 6380 to
# avoid colliding with a system valkey/redis daemon on 6379. In prod
# (compose.prod.yml) this is just `redis:6379` inside the docker network — see
# compose.prod.yml for the override.
COMIC_REDIS_URL=redis://localhost:6380

# WARNING — the next two paths default to dev locations (relative to the
# repo root). For a docker-compose deployment, **leave them unset** so
# the Dockerfile defaults apply (`COMIC_LIBRARY_PATH=/library`,
# `COMIC_DATA_PATH=/data`). The compose file already mounts the host
# library + named secrets-volume to those exact paths. Setting these to
# `./.dev-data/...` inside a container points the server at an
# ephemeral path in the writable layer — the pepper, JWT key, etc. get
# regenerated on every `docker compose up -d`, which locks every user
# out of their old password hash.
COMIC_LIBRARY_PATH=./fixtures/library
COMIC_DATA_PATH=./.dev-data/app
COMIC_PUBLIC_URL=http://localhost:3000
COMIC_BIND_ADDR=0.0.0.0:8080
COMIC_LOG_LEVEL=info  # DEPRECATED, manage via /admin/server
COMIC_TRUSTED_PROXIES=127.0.0.0/8,::1/128

# ───── Auth mode — DEPRECATED, manage via /admin/auth ─────
# Bootstrapped into `app_setting` on first boot, then ignored on
# subsequent boots. Edit identity config through the admin UI rather
# than this file.
# oidc | local | both
COMIC_AUTH_MODE=both

# ───── OIDC — DEPRECATED, manage via /admin/auth ─────
COMIC_OIDC_ISSUER=http://localhost:5556/dex
COMIC_OIDC_CLIENT_ID=comic-reader
COMIC_OIDC_CLIENT_SECRET=dev-secret-not-for-production
COMIC_OIDC_TRUST_UNVERIFIED_EMAIL=false
# COMIC_OIDC_CLIENT_SECRET_FILE=/run/secrets/oidc

# ───── Local users — DEPRECATED, manage via /admin/auth ─────
COMIC_LOCAL_REGISTRATION_OPEN=true

# ───── Tokens — DEPRECATED, manage via /admin/auth ─────
COMIC_JWT_ACCESS_TTL=24h
COMIC_JWT_REFRESH_TTL=30d

# ───── Rate limiting — DEPRECATED, manage via /admin/server ─────
# When false, the failed-auth Redis lockout short-circuits (per-route
# governor buckets stay installed; they require a restart to disable).
COMIC_RATE_LIMIT_ENABLED=true

# ───── Observability ─────
# Empty value → stdout exporter only
COMIC_OTLP_ENDPOINT=

# ───── SMTP — DEPRECATED, manage via /admin/email ─────
# These env vars are still read on first boot and bootstrapped into the
# `app_setting` table, then ignored on subsequent boots. After upgrading,
# edit SMTP through the admin UI (`/admin/email`) rather than this file.
# Leave COMIC_SMTP_HOST empty to start in the no-SMTP "noop" mode; you can
# then configure email via the admin UI without restarting.
COMIC_SMTP_HOST=
COMIC_SMTP_PORT=587
COMIC_SMTP_USERNAME=
COMIC_SMTP_PASSWORD=
COMIC_SMTP_TLS=starttls
# COMIC_SMTP_FROM=noreply@example.com  (uncomment + set when SMTP is configured;
# avoid display-name + angle-brackets here — `just` dotenv parser is strict)

# ───── Scan / archive limits — not yet plumbed through to enforcement ─────
# Spec'd in §4.1.1 but currently `archive::ArchiveLimits::default()` is
# used everywhere; these env vars do nothing today. Plumbing them is
# tracked as future work.
# COMIC_ARCHIVE_MAX_ENTRIES=50000
# COMIC_ARCHIVE_MAX_TOTAL_BYTES=8589934592
# COMIC_ARCHIVE_MAX_ENTRY_BYTES=536870912
# COMIC_ARCHIVE_MAX_RATIO=200
# COMIC_ARCHIVE_MAX_NESTING=1

# ───── ZIP LRU — DEPRECATED, manage via /admin/server ─────
# Applies on next restart (the LRU is sized at boot).
# COMIC_ZIP_LRU_CAPACITY=64

# ───── Workers — DEPRECATED, manage via /admin/server ─────
# Apply on next restart (apalis pool size is fixed at startup; live
# pool restart is deferred future work).
# COMIC_SCAN_WORKER_COUNT=4         # parallel scan jobs (default min(cpu, 4))
# COMIC_POST_SCAN_WORKER_COUNT=2    # parallel post-scan jobs (thumbs/search)
# COMIC_SCAN_BATCH_SIZE=100         # issues per DB transaction
# COMIC_SCAN_HASH_BUFFER_KB=64      # BLAKE3 streaming buffer
# COMIC_ARCHIVE_WORK_PARALLEL=4     # global cap on blocking archive work
# COMIC_THUMB_INLINE_PARALLEL=4     # cap on on-demand thumbnail generation

# ───── Migrations ─────
COMIC_AUTO_MIGRATE=true

# ───── Deployment (compose.prod.yml) ─────
# These drive `compose.prod.yml` placeholders; they have no effect on a
# local `cargo run` or `pnpm dev` session.

# GHCR owner/org that holds your published images:
#   ghcr.io/${REPO_OWNER}/folio        (Rust server)
#   ghcr.io/${REPO_OWNER}/folio-web    (Next.js frontend)
REPO_OWNER=your-github-username-or-org

# Image tag to deploy. Use `vX.Y` for hands-off patch upgrades, `vX.Y.Z`
# to pin exactly, `edge` to track main. Default is `latest`.
TAG=latest

# Postgres password for the `comic` user (compose initializes the DB on
# first boot with this value). Pick something long and random.
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# Absolute host path that holds your CBZ/CBR/PDF/EPUB library. Mounted
# read-only into the container at `${COMIC_LIBRARY_PATH}` (default
# `/library`). For path symmetry between dev (native binary) and prod
# (container), set both to the same value, e.g.:
#   COMIC_LIBRARY_HOST_PATH=/mnt/data
#   COMIC_LIBRARY_PATH=/mnt/data
COMIC_LIBRARY_HOST_PATH=/mnt/data

# Host interface for the published API + web ports. Default is 127.0.0.1
# so a reverse proxy on the same host is the only reachable entry point.
# Set to 0.0.0.0 on a trusted LAN (homelab) or when you also want a
# Cloudflare tunnel and direct LAN access to coexist. Leave at 127.0.0.1
# on a public-internet host — the API and Next process have no TLS of
# their own, so a proxy in front is mandatory there.
COMIC_APP_BIND=0.0.0.0
COMIC_WEB_BIND=0.0.0.0
