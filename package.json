{
  "name": "comic-reader",
  "private": true,
  "version": "0.0.0",
  "description": "Self-hostable comic reader (workspace root)",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "lint": "pnpm --recursive run lint",
    "lint:fix": "pnpm --recursive run lint:fix",
    "format": "pnpm --recursive run format",
    "format:check": "pnpm --recursive run format:check",
    "typecheck": "pnpm --recursive run typecheck",
    "test": "pnpm --recursive run test",
    "openapi:gen": "pnpm --filter web run openapi:gen"
  },
  "dependencies": {
    "@playwright/test": "^1.59.1"
  },
  "pnpm": {
    "overrides": {
      "lodash@<4.18.0": "4.18.1",
      "js-yaml@>=4.0.0 <4.1.1": "4.2.0",
      "serialize-javascript@<7.0.5": "7.0.5",
      "yaml@>=1.0.0 <1.10.3": "1.10.3",
      "postcss@<8.5.10": "8.5.15"
    }
  }
}
